<?xml version="1.0"?>
<robot name="my_robot">

    <link name="base_link">

        <visual>
            <origin xyz="0.15 0 0" rpy="0 0 0"/>
            <geometry>
            <!-- Asymmetric box: length 0.3, width 0.2, height 0.1, shifted 0.15m in +x -->
            <box size="0.3 0.2 0.1"/> 
            </geometry>
            <material name="blue">
            <color rgba="0 0 1 1"/> </material>
        </visual>

        <collision>
            <origin xyz="0.15 0 0" rpy="0 0 0"/>
            <geometry>
            <box size="0.3 0.2 0.1"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.0"/> <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>

    </link>

  <!-- Left wheel -->

    <link name="left_wheel">
        <visual>
            <geometry>
            <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <material name="black">
            <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
            <cylinder radius="0.05" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>  
        <child link="left_wheel"/>  
        <origin xyz="0 0.125 -0.05" rpy="-1.57 0 0"/>  <!-- x=0, y at left edge -->
        <axis xyz="0 0 1"/>
    </joint>

  <!-- Right wheel -->
    <link name="right_wheel">
        <visual>
            <geometry>
            <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <material name="black">
            <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
            <cylinder radius="0.05" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.125 -0.05" rpy="-1.57 0 0"/>  <!-- x=0, y at right edge -->
        <axis xyz="0 0 1"/>
    </joint>

  <!-- Caster wheel -->
    <link name="caster_wheel">
        <visual>
            <geometry>
            <sphere radius="0.05"/>
            </geometry>
            <material name="white">
            <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
            <sphere radius="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="2.0"/>
            <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
        </inertial>
    </link>

    <joint name="caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="0.3 0 -0.05"/>  <!-- At front, half-embedded in baselink -->
    </joint>

    <!-- Make caster wheel frictionless for smooth spinning: no more drift to sideways -->
    <gazebo reference="caster_wheel">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <material>Gazebo/White</material>
    </gazebo>

    <!-- define lidar-->
    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
            <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.07" rpy="0 0 0"/>  <!-- x=0, on top of baselink -->
    </joint>

    <gazebo reference="lidar_link">
        <sensor name="lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <topic>scan</topic>
            <ray>
            <scan>
                <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14</min_angle>
                <max_angle>3.14</max_angle>
                </horizontal>
                <vertical>
                <samples>1</samples>
                <!-- the error if lidar is 0.01 m-->
                <resolution>0.01</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
                </vertical>
            </scan>
            <range>
                <min>0.08</min>
                <max>10.0</max>
                <resolution>0.01</resolution>
            </range>
            <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.01</stddev>
            </noise>
            </ray>
            <gz_frame_id>lidar_link</gz_frame_id>
        </sensor>
    </gazebo>

    <!-- ================= OAK-D camera (mirrors TurtleBot 4) ================= -->
    <!-- Frame tree matches the real robot so topics/TF are drop-in:            -->
    <!--   base_link -> oakd_link -> oakd_rgb_camera_frame                       -->
    <!--                          -> oakd_rgb_camera_optical_frame (REP-145)     -->
    <link name="oakd_link">
        <visual>
            <geometry>
                <box size="0.02 0.09 0.02"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.15 0.15 0.15 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.09 0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>

    <!-- Mount at the front face of base_link (x=0.3), near the top (z=0.05), looking +x -->
    <joint name="oakd_joint" type="fixed">
        <parent link="base_link"/>
        <child link="oakd_link"/>
        <origin xyz="0.30 0 0.05" rpy="0 0 0"/>
    </joint>

    <!-- Body camera frame: +x forward, aligned with oakd_link -->
    <link name="oakd_rgb_camera_frame"/>
    <joint name="oakd_rgb_camera_joint" type="fixed">
        <parent link="oakd_link"/>
        <child link="oakd_rgb_camera_frame"/>
        <origin xyz="0.01 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Optical frame: REP-145 (z forward, x right, y down). This is the frame -->
    <!-- stamped on Image/CameraInfo and used for pinhole deprojection.          -->
    <link name="oakd_rgb_camera_optical_frame"/>
    <joint name="oakd_rgb_camera_optical_joint" type="fixed">
        <parent link="oakd_rgb_camera_frame"/>
        <child link="oakd_rgb_camera_optical_frame"/>
        <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    </joint>

    <!-- RGB + depth sensors. Both 640x480 @ ~69deg HFOV so depth pixels align   -->
    <!-- 1:1 with RGB. Headers stamped with the optical frame via gz_frame_id.    -->
    <gazebo reference="oakd_rgb_camera_frame">
        <sensor name="oakd_rgb" type="camera">
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>15</update_rate>
            <topic>oakd/rgb/image_raw</topic>
            <camera_info_topic>oakd/rgb/camera_info</camera_info_topic>
            <gz_frame_id>oakd_rgb_camera_optical_frame</gz_frame_id>
            <camera>
                <horizontal_fov>1.2043</horizontal_fov>  <!-- 69 deg, OAK-D-Pro RGB nominal -->
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>15.0</far>
                </clip>
            </camera>
        </sensor>

        <sensor name="oakd_depth" type="depth_camera">
            <always_on>true</always_on>
            <update_rate>15</update_rate>
            <!-- gz publishes 32FC1 metres here; depth_to_mm republishes 16UC1 mm -->
            <!-- as /oakd/stereo/image_raw to match the real depthai driver.       -->
            <topic>oakd/stereo/image_float</topic>
            <camera_info_topic>oakd/stereo/camera_info</camera_info_topic>
            <gz_frame_id>oakd_rgb_camera_optical_frame</gz_frame_id>
            <camera>
                <horizontal_fov>1.2043</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R_FLOAT32</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>15.0</far>
                </clip>
            </camera>
        </sensor>
    </gazebo>


    <!-- Diff Drive Plugin to move robot-->
    <gazebo>
        <plugin filename="libignition-gazebo-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
            
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            
            <wheel_separation>0.25</wheel_separation>
            <wheel_radius>0.05</wheel_radius>
            
            <max_linear_acceleration>1</max_linear_acceleration>
            <min_linear_acceleration>-1</min_linear_acceleration>
            <max_angular_acceleration>2</max_angular_acceleration>
            <min_angular_acceleration>-2</min_angular_acceleration>
            <max_linear_velocity>0.5</max_linear_velocity>
            <min_linear_velocity>-0.5</min_linear_velocity>
            <max_angular_velocity>1</max_angular_velocity>
            <min_angular_velocity>-1</min_angular_velocity>

            <topic>/cmd_vel</topic>
            
            <odom_topic>odom_raw</odom_topic>
            <tf_topic>tf_gazebo_exact</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_link</child_frame_id>
            <odom_publisher_frequency>30</odom_publisher_frequency>
            
        </plugin>
    </gazebo>

</robot>