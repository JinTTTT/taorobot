<?xml version="1.0"?>
<model>
  <name>office</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <description>
    Office scene (frame/shell, tables, chairs, plants) imported from the
    APP-RAS project. Visual-only STL meshes: the lidar raycasts the render
    scene, so mapping/SLAM still sees the walls without collision geometry
    (full-res STL collisions tank the physics real-time factor). The building
    shell spans roughly x[-18.5,-1.4] y[-67,-10] with the floor at z~=0.
  </description>
</model>
